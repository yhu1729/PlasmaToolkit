#pragma once

#cmakedefine PT_CANARY @PT_CANARY@
#cmakedefine PT_VERBOSITY @PT_VERBOSITY@

#cmakedefine PT_USE_TYPE
#cmakedefine PT_USE_MPI
#cmakedefine PT_USE_NCCL

#if PT_CANARY > 0
#define PT_OPTION_ABORT_ON_ERROR
#endif
#if PT_CANARY > 1
#endif
#if PT_CANARY > 2
#endif

#ifdef PT_USE_MPI
#include "mpi.h"
#endif

#ifdef PT_USE_NCCL
#include "nccl.h"
#endif

#include <stdint.h>
typedef uint_fast8_t pt_u8;
typedef uint_fast16_t pt_u16;
typedef uint_fast32_t pt_u32;
typedef uint_fast64_t pt_u64;
typedef int_fast8_t pt_i8;
typedef int_fast16_t pt_i16;
typedef int_fast32_t pt_i32;
typedef int_fast64_t pt_i64;
typedef float pt_f32;
typedef double pt_f64;
typedef long double pt_f128;
#ifdef PT_USE_TYPE
typedef pt_u8 u8;
typedef pt_u16 u16;
typedef pt_u32 u32;
typedef pt_u64 u64;
typedef pt_i8 i8;
typedef pt_i16 i16;
typedef pt_i32 i32;
typedef pt_i64 i64;
typedef pt_f32 f32;
typedef pt_f64 f64;
typedef pt_f128 f128;
#endif
